record(ai, "MDO:getTemp"){
    field(DESC, "Asks for temperature")
    field(DTYP, "stream")
    field(INP, "@MDO.proto getTemp L0 0")
}
record(ao, "MDO:setTemp"){
    field(DESC, "Sends temperature to simulator")
    field(DTYP, "stream")
    field(OUT, "@MDO.proto setTemp L0 0")
}
record(stringin, "MDO:getStatus"){
    field(DESC, "Asks for status")
    field(DTYP, "stream")
    field(INP, "@MDO.proto getStatus L0 0")
}
record(stringout, "MDO:setStatus"){
    field(DESC, "Sends status to simulator")
    field(DTYP, "stream")
    field(OUT, "@MDO.proto setStatus L0 0")
}
